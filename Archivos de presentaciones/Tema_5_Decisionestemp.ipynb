    "#Autor: Carlos Juarez\n",
    "#Fecha: 25/03/25\n",
    "#Descripción: Programa para definir si un número es positivo o negativo o cero\n",
    "\n",
    "n = float(input(\"Ingrese un número: \"))\n",
    "if n == 0:\n",
    "    print(f'{n} es elemento neutro')\n",
    "else:\n",
    "    if n > 0:\n",
    "        print(f'{n} es positivo')\n",
    "    else:\n",
    "        print(f'{n} es negativo')"
